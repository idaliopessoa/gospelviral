dist/
build/
.cache/
.parcel-cache/
.next/
.vite/

# Test + coverage
coverage/
*.lcov
.nyc_output/
.vitest-cache/

# Sonar
.scannerwork/
.sonar/

# OS / editor noise
.DS_Store
Thumbs.db
.idea/

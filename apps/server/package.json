{
  "name": "@gospelviral/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file-if-exists=../../.env.local src/server.js",
    "start": "node --env-file-if-exists=../../.env.local src/server.js",
    "build": "echo 'no build step (node esm)'",
    "smoke:api": "node scripts/smoke-api.js",
    "smoke:cli": "node scripts/smoke-cli.js",
    "smoke:heap": "node --expose-gc scripts/smoke-heap.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src"
  },
  "dependencies": {
    "@gospelviral/shared": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "busboy": "^1.6.0",
    "hono": "^4.6.14",
    "which": "^5.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "vitest": "^2.1.8"
  }
}
